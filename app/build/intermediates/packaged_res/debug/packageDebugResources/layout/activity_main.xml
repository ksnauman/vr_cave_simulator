<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050C14">

    <!-- GL VR Surface -->
    <android.opengl.GLSurfaceView
        android:id="@+id/glSurfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Frost scene-transition overlay -->
    <View
        android:id="@+id/sceneTransitionOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E8F4FF"
        android:alpha="0"
        android:visibility="gone" />

    <!-- Info Card Overlay (centred, both eyes see it) -->
    <FrameLayout
        android:id="@+id/infoCardContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Dim backdrop (lightened) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000" />

        <!-- Card (more transparent) -->
        <LinearLayout
            android:layout_width="500dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="#99050C14"
            android:padding="24dp">
 
            <TextView
                android:id="@+id/infoCardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E8F4FF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />
 
            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#3090C8E8"
                android:layout_marginBottom="14dp" />
 
            <TextView
                android:id="@+id/infoCardBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#B0D8F0"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnCloseInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="CLOSE"
                android:textColor="#E8F4FF"
                android:backgroundTint="#1A4A7A" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
